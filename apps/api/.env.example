# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/dna-referee-management

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d

# Application
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
PRODUCTION_URL=https://your-production-domain.com

# WhatsApp GREEN-API Configuration
# Get your credentials at: https://green-api.com/
GREENAPI_INSTANCE_ID=
GREENAPI_TOKEN=

# Notification Scheduler Configuration (optional)
MATCH_REMINDER_HOURS=24
SEMINAR_REMINDER_HOURS=48

# SMTP Email Configuration
# For Gmail: use smtp.gmail.com, port 587, SMTP_SECURE=false
# Create App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=DNA Arbitrage
SMTP_FROM_EMAIL=noreply@dna.tn
